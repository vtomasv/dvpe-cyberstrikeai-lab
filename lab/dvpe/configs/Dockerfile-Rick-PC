# Usa la imagen base de Ubuntu
FROM ubuntu:22.04

# Actualiza el sistema e instala herramientas básicas
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    openssh-server \
    git \
    nano \
    curl \
    wget \
    iputils-ping \
    net-tools \
    netcat \
    nmap && \
    rm -rf /var/lib/apt/lists/*


# Configura el servicio SSH para permitir acceso remoto
RUN mkdir /var/run/sshd
RUN echo 'root:ngAQEa5AqgN@V5Hr' | chpasswd
RUN sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config

RUN echo "flag{36d80ec698b0c198a1106f26c9e07a4}" >> /root/flag.txt

# Dejar tools para pivoting
RUN mkdir -p /root/Documents/tools
WORKDIR /root/Documents/tools
# El toolkit original NO se versiona en el repo del lab; se descarga del upstream.
ARG DVPE_TOOLKIT_URL=https://github.com/franc205/dvpe/raw/main/configs/files/toolkit.tar.gz
RUN curl -fL --retry 5 --retry-delay 2 -o toolkit.tar.gz "${DVPE_TOOLKIT_URL}" \
 && tar -xzvf toolkit.tar.gz \
 && rm toolkit.tar.gz

# Exponer el puerto SSH
EXPOSE 22

# Comando predeterminado para iniciar SSH y Bash
#CMD ["/usr/sbin/sshd", "-D"]
CMD ["/bin/bash"]