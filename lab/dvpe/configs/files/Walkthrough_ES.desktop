[Desktop Entry]
Version=1.0
Type=Application
Name=Walkthrough_ES
Comment=Guía interactiva del laboratorio DVPE × CyberStrikeAI (servida por el contenedor Lab-Guide)
Exec=bash -c 'URL="http://lab-guide"; PROFILE="default"; firefox-esr  > /dev/null 2>&1 & sleep 1; kill $!; sleep 0; firefox-esr -P "$PROFILE" "$URL" &'
Icon=text-html
Terminal=false
