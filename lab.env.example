# ---------------------------------------------------------------------------
# dvpe-cyberstrikeai-lab — variables del laboratorio Docker
# Copia este archivo como `.env` JUNTO al docker-compose.yml ANTES de levantar
# el laboratorio (`cp lab.env.example .env`).
# Este archivo NO afecta al frontend webdev; sólo lo lee docker compose.
# ---------------------------------------------------------------------------

# Versión / rama de CyberStrikeAI que se clonará dentro de la imagen.
CYBERSTRIKEAI_REF=main

# Endpoint del host Docker donde corre Ollama. En Docker Desktop (Win/Mac)
# basta con el valor por defecto; en Linux el compose añade host-gateway
# automáticamente, así que tampoco hace falta cambiarlo.
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434

# Cliente "OpenAI-compatible" usado por CyberStrikeAI para hablar con Ollama
# a través del proxy interno (ollama-proxy:11434).
CSAI_OPENAI_BASE_URL=http://ollama-proxy:11434/v1
CSAI_OPENAI_API_KEY=ollama
CSAI_OPENAI_MODEL=llama3.1:8b
